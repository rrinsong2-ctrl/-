      "source": [
        "# ============================================\n",
        "# 1. 라이브러리\n",
        "# ============================================\n",
        "\n",
        "import os\n",
        "import zipfile\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.preprocessing import StandardScaler, LabelEncoder\n",
        "from sklearn.ensemble import RandomForestClassifier\n",
        "from sklearn.metrics import accuracy_score, confusion_matrix\n",
        "\n",
        "from sklearn.decomposition import PCA\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# ============================================\n",
        "# 2. 압축 해제\n",
        "# ============================================\n",
        "\n",
        "zip_path = \"/content/gas+sensor+array+exposed+to+turbulent+gas+mixtures (1).zip\"\n",
        "\n",
        "extract_path = \"/content/gas_dataset\"\n",
        "\n",
        "with zipfile.ZipFile(zip_path, 'r') as zip_ref:\n",
        "    zip_ref.extractall(extract_path)\n",
        "\n",
        "print(\"압축 해제 완료\")\n",
        "\n",
        "# ============================================\n",
        "# 3. 데이터 파일 경로\n",
        "# ============================================\n",
        "\n",
        "data_folder = \"/content/gas_dataset/dataset_twosources_raw\"\n",
        "\n",
        "all_files = []\n",
        "\n",
        "for file in os.listdir(data_folder):\n",
        "\n",
        "    full_path = os.path.join(data_folder, file)\n",
        "\n",
        "    if os.path.isfile(full_path):\n",
        "\n",
        "        all_files.append(full_path)\n",
        "\n",
        "print(\"파일 개수:\", len(all_files))\n",
        "\n",
        "# ============================================\n",
        "# 4. 데이터 읽기\n",
        "# ============================================\n",
        "\n",
        "X = []\n",
        "y = []\n",
        "\n",
        "for file_path in all_files:\n",
        "\n",
        "    filename = os.path.basename(file_path)\n",
        "\n",
        "    # ----------------------------------------\n",
        "    # 라벨 설정\n",
        "    # ----------------------------------------\n",
        "\n",
        "    if \"Me\" in filename:\n",
        "        label = \"Methanol\"\n",
        "\n",
        "    elif \"CO\" in filename:\n",
        "        label = \"CO\"\n",
        "\n",
        "    else:\n",
        "        label = \"Other\"\n",
        "\n",
        "    # ----------------------------------------\n",
        "    # CSV 형태 데이터 읽기\n",
        "    # delimiter=',' 추가가 핵심\n",
        "    # ----------------------------------------\n",
        "\n",
        "    data = np.loadtxt(file_path, delimiter=',')\n",
        "\n",
        "    # ----------------------------------------\n",
        "    # 특징 추출\n",
        "    # 각 센서 평균값 사용\n",
        "    # ----------------------------------------\n",
        "\n",
        "    features = np.mean(data, axis=0)\n",
        "\n",
        "    X.append(features)\n",
        "    y.append(label)\n",
        "\n",
        "# ============================================\n",
        "# 5. DataFrame 생성\n",
        "# ============================================\n",
        "\n",
        "X = pd.DataFrame(X)\n",
        "\n",
        "y = pd.Series(y)\n",
        "\n",
        "print(\"\\n데이터 shape:\", X.shape)\n",
        "\n",
        "print(\"\\n가스 종류:\")\n",
        "print(y.unique())\n",
        "\n",
        "# ============================================\n",
        "# 6. 라벨 인코딩\n",
        "# ============================================\n",
        "\n",
        "encoder = LabelEncoder()\n",
        "\n",
        "y_encoded = encoder.fit_transform(y)\n",
        "\n",
        "# ============================================\n",
        "# 7. 데이터 정규화\n",
        "# ============================================\n",
        "\n",
        "scaler = StandardScaler()\n",
        "\n",
        "X_scaled = scaler.fit_transform(X)\n",
        "\n",
        "# ============================================\n",
        "# 8. 학습 / 테스트 분리\n",
        "# ============================================\n",
        "\n",
        "X_train, X_test, y_train, y_test = train_test_split(\n",
        "    X_scaled,\n",
        "    y_encoded,\n",
        "    test_size=0.2,\n",
        "    random_state=42,\n",
        "    stratify=y_encoded\n",
        ")\n",
        "\n",
        "# ============================================\n",
        "# 9. Random Forest 모델\n",
        "# ============================================\n",
        "\n",
        "model = RandomForestClassifier(\n",
        "    n_estimators=200,\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "# ============================================\n",
        "# 10. 모델 학습\n",
        "# ============================================\n",
        "\n",
        "print(\"\\n모델 학습 중...\")\n",
        "\n",
        "model.fit(X_train, y_train)\n",
        "\n",
        "print(\"학습 완료\")\n",
        "\n",
        "# ============================================\n",
        "# 11. 정확도 평가\n",
        "# ============================================\n",
        "\n",
        "y_pred = model.predict(X_test)\n",
        "\n",
        "accuracy = accuracy_score(y_test, y_pred)\n",
        "\n",
        "print(\"\\n===================================\")\n",
        "print(\"모델 정확도:\", round(accuracy * 100, 2), \"%\")\n",
        "print(\"===================================\")\n",
        "\n",
        "# ============================================\n",
        "# 12. Confusion Matrix 시각화\n",
        "# ============================================\n",
        "\n",
        "cm = confusion_matrix(y_test, y_pred)\n",
        "\n",
        "plt.figure(figsize=(6,6))\n",
        "\n",
        "plt.imshow(cm)\n",
        "\n",
        "plt.title(\"Confusion Matrix\")\n",
        "\n",
        "plt.colorbar()\n",
        "\n",
        "plt.xlabel(\"Predicted\")\n",
        "plt.ylabel(\"Actual\")\n",
        "\n",
        "plt.show()\n",
        "\n",
        "# ============================================\n",
        "# 13. PCA 시각화\n",
        "# ============================================\n",
        "\n",
        "pca = PCA(n_components=2)\n",
        "\n",
        "X_pca = pca.fit_transform(X_scaled)\n",
        "\n",
        "plt.figure(figsize=(8,6))\n",
        "\n",
        "scatter = plt.scatter(\n",
        "    X_pca[:,0],\n",
        "    X_pca[:,1],\n",
        "    c=y_encoded,\n",
        "    alpha=0.8\n",
        ")\n",
        "\n",
        "plt.title(\"PCA Visualization\")\n",
        "\n",
        "plt.xlabel(\"PCA 1\")\n",
        "plt.ylabel(\"PCA 2\")\n",
        "\n",
        "plt.colorbar(scatter)\n",
        "\n",
        "plt.show()\n",
        "\n",
        "# ============================================\n",
        "# 14. 실시간 메탄올 감지\n",
        "# ============================================\n",
        "\n",
        "print(\"\\n===== 실시간 가스 감지 =====\")\n",
        "\n",
        "sample = X.iloc[0].values.reshape(1,-1)\n",
        "\n",
        "sample_scaled = scaler.transform(sample)\n",
        "\n",
        "prediction = model.predict(sample_scaled)\n",
        "\n",
        "predicted_gas = encoder.inverse_transform(prediction)\n",
        "\n",
        "print(\"감지된 가스:\", predicted_gas[0])\n",
        "\n",
        "# ============================================\n",
        "# 15. 위험 경고 시스템\n",
        "# ============================================\n",
        "\n",
        "if predicted_gas[0] == \"Methanol\":\n",
        "\n",
        "    print(\"\\n⚠ 메탄올 유출 감지!\")\n",
        "    print(\"실험실 연구원에게 경고 전송\")\n",
        "    print(\"환기 시스템 작동 필요\")\n",
        "\n",
        "else:\n",
        "\n",
        "    print(\"\\n정상 상태\")"
